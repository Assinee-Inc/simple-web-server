{
  "scripts": {
    "css": "tailwindcss -i web/assets/css/input.css -o web/assets/css/output.css",
    "css:watch": "tailwindcss -i web/assets/css/input.css -o web/assets/css/output.css --watch",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:checkout": "cypress run --spec 'cypress/e2e/checkout/**/*.cy.js'"
  },
  "devDependencies": {
    "cypress": "^13.17.0",
    "tailwindcss": "^3.4.19"
  }
}

