.specify

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Cypress
cypress/videos/
cypress/screenshots/
# cypress.env.json holds real secrets (API keys, seeded IDs) — never commit
cypress.env.json
node_modules/

# Build output directory (never commit binaries)
bin/
dist/
build/

# IA generated files
.gemini
.specify

# Universal ignores
Thumbs.db
*.tmp
*.swp
*.log
